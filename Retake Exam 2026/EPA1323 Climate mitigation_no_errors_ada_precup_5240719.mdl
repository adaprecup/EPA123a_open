{UTF-8}
Initial planned capacity fossil resources=
	6e+07
	~	bbtu/Year
	~		|

Initial planned capacity of renewable resources=
	8.08e+07
	~	bbtu/Year
	~		|

Initial production capacity of fossil resources=
	4.15e+08
	~	bbtu/Year
	~		|

Initial renewable energy production capacity=
	5e+07
	~	bbtu/Year
	~		|

Planned capacity fossil resources= INTEG (
	Planning of new fossil capacity-Commissioning of new fossil capacity,
		Initial planned capacity fossil resources)
	~	bbtu/Year
	~		|

GWP= INTEG (Increase GWP,
		Initial GWP)
	~	dollar/Year
	~		|

Renewable energy production capacity= INTEG (
	Commissioning of new renewable capacity-Decommissioning of renewable capacity,
		Initial renewable energy production capacity)
	~	bbtu/Year
	~		|

Production capacity of fossil resources= INTEG (
	Commissioning of new fossil capacity-Decommissioning of fossil capacity,
		Initial production capacity of fossil resources)
	~	bbtu/Year
	~		|

Planned capacity of renewable resources= INTEG (
	Planning of new renewable capacity-Commissioning of new renewable capacity,
		Initial planned capacity of renewable resources)
	~	bbtu/Year
	~		|

Initial GWP=
	7.8e+13
	~	dollar/Year
	~		|

Initial investments in decoupling driven by energy shortages=
	0.05
	~	Dmnl
	~		|

Intrinsic energy demand=
	GWP * Energy intensity of GWP
	~	bbtu/Year
	~		|

Investment delay time energy decoupling=
	8
	~	Year
	~		|

Commissioning of new fossil capacity=
	DELAY3I ( Planning of new fossil capacity , Planning delay new fossil resources , Planned capacity fossil resources\
		 / Planning delay new fossil resources )
	~	bbtu/(Year*Year)
	~		|

Commissioning of new renewable capacity=DELAY3I ( Planned capacity of renewable resources\
		 / Planning delay time new renewable resources , Planning delay time new renewable resources\
		 , Planned capacity of renewable resources / Planning delay time new renewable resources\
		 )
	~	bbtu/(Year*Year)
	~		|

Initial energy intensity of GWP=5.54e-06
	~	bbtu/dollar
	~		|

Decreasing Energy intensity of GWP=
	Energy intensity of GWP * Investments in decoupling driven by energy shortages
	~	bbtu/dollar/Year
	~		|

Energy intensity of GWP= INTEG (
	-Decreasing Energy intensity of GWP,
		Initial energy intensity of GWP)
	~	bbtu/dollar
	~		|

Decoupling due to energy shortages=
	0.25
	~	1/Year
	~		|

Investments in decoupling driven by energy shortages=Decoupling due to energy shortages\
		 * SMOOTH3I( MAX ( Fraction energy demand to energy supply, 0 ) -1 , Investment delay time energy decoupling\
		 , Initial investments in decoupling driven by energy shortages )
	~	1/Year
	~		|

Extension of renewables driven by subsidies= WITH LOOKUP (Time,
		([(2015,0)-(2065,0.2)],(2015,0.1),(2035,0),(2065,0) ))
	~	1/Year
	~		|

Planning of new renewable capacity=
	( Extension of renewables driven by subsidies + Relative capacity extension driven by profitability\
		 ( Relative profitability of renewable resources ) ) * Renewable energy production capacity
	~	bbtu/(Year*Year)
	~		|

Decommissioning of fossil capacity=
	Production capacity of fossil resources / Life expectancy fossil capacity
	~	bbtu/Year/Year
	~		|

Decommissioning of renewable capacity=
	Renewable energy production capacity / Life expectancy renewable capacity
	~	bbtu/Year/Year
	~		|

Decreasing costs of renewables=
	Costs of renewable energy * Annual decrease renewable energy costs
	~	dollar/(bbtu*Year)
	~		|

Autonomous economic growth=
	0.03
	~	1/Year
	~		|

Reduction of the GWP increase due to energy shortages=
	(Fraction energy demand to energy supply - 1) * Factor reduction of GWP increase due to energy shortages
	~	1/Year
	~		|

Factor reduction of GWP increase due to energy shortages=
	0.1
	~	1/Year
	~		|

Average energy price=MIN ( Costs of fossil extraction, Costs of renewable energy ) * \
		Price change due to energy shortages
	~	dollar/bbtu
	~		|

Initial costs renewable energy=
	20000
	~	dollar/bbtu
	~		|

Annual decrease renewable energy costs=
	0.07
	~	1/Year
	~		|

Costs of fossil extraction=
	5000
	~	dollar/bbtu
	~		|

Costs of renewable energy= INTEG (+Decreasing costs of renewables,
		Initial costs renewable energy)
	~	dollar/bbtu
	~		|

Life expectancy fossil capacity=
	40
	~	Year
	~		|

Life expectancy renewable capacity=
	30
	~	Year
	~		|

Planning of new fossil capacity=
	Relative capacity extension driven by profitability(Relative profitability of fossil resources\
		) * Production capacity of fossil resources
	~	bbtu/(Year*Year)
	~		|

Planning delay new fossil resources=
	10
	~	Year
	~		|

Planning delay time new renewable resources=
	10
	~	Year
	~		|

Price change due to energy shortages= WITH LOOKUP (Fraction energy demand to energy supply\
		,
		([(0,0)-(2,3)],(0,0), (0.5,0.18), (0.8,0.25), (0.95,0.5), (1.05,1.5), (1.2,2), (1.5\
		,2.5), (2,3)))
	~	Dmnl
	~		|

Relative share renewable resources=
	Renewable energy production capacity / ( Renewable energy production capacity + Production capacity of fossil resources\
		 )
	~	Dmnl
	~		|

Relative capacity extension driven by profitability(
	[(0,0)-(10,0.2)],(0,0),(1,0),(1.1,0.02),(1.5,0.05),(2,0.1),(4,0.15),(10,0.18))
	~	1/Year
	~		|

Relative profitability of fossil resources=
	Average energy price / Costs of fossil extraction
	~	Dmnl
	~		|

Relative profitability of renewable resources=
	Average energy price  / Costs of renewable energy
	~	Dmnl
	~		|

Increase GWP=(Autonomous economic growth - Reduction of the GWP increase due to energy shortages\
		) * GWP
	~	dollar/Year/Year
	~		|

Fraction energy demand to energy supply=
	Intrinsic energy demand  / ( Production capacity of fossil resources + Renewable energy production capacity\
		)
	~	Dmnl
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 2065
	~	Year
	~	The final time for the simulation.
	|

INITIAL TIME  = 2015
	~	Year
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Year [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.03125
	~	Year [0,?]
	~	The time step for the simulation.
	|

